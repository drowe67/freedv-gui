     const size_t count = m_textLines.size();
     for ( size_t n = 0; n < count; n++ )
     {
-        dc.DrawText(m_textLines[n], pt);
+#if defined(WIN32)
+        if (context != nullptr)
+        {
+            context->DrawText(m_textLines[n], pt.x, pt.y);
+        }
+        else
+#endif // defined(WIN32)
+        {
+            dc.DrawText(m_textLines[n], pt);
+        }
 
         pt.y += m_heightLine;
     }
+
+#if defined(WIN32)
+    if (context != nullptr)
+    {
+        delete context;
+    }
+#endif // defined(WIN32)
 }
 
